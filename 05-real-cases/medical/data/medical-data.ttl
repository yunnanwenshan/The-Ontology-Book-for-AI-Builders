@prefix ex: <http://hospital.com/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# === 3 个科室 ===
ex:dept-cardio a ex:Department ; ex:deptName "心血管内科" .
ex:dept-resp   a ex:Department ; ex:deptName "呼吸内科" .
ex:dept-peds   a ex:Department ; ex:deptName "儿科" .

# === 4 个医生 ===
ex:doc-001 a ex:Doctor ; ex:doctorName "李华" ; ex:licenseNo "110108197801011234" ; ex:department ex:dept-cardio ; ex:doctorTitle "主任医师" .
ex:doc-002 a ex:Doctor ; ex:doctorName "王芳" ; ex:licenseNo "110108198503056789" ; ex:department ex:dept-resp   ; ex:doctorTitle "副主任医师" .
