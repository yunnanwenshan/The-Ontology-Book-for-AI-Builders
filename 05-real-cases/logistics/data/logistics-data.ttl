@prefix ex: <http://logistics.com/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# === 4 个仓库 ===
ex:wh-shanghai a ex:Warehouse ; ex:warehouseCode "WH-SHA" ; ex:warehouseName "上海主仓" ; ex:warehouseCity "上海" ; ex:warehouseLat 31.23 ; ex:warehouseLng 121.47 .
ex:wh-shenzhen a ex:Warehouse ; ex:warehouseCode "WH-SZX" ; ex:warehouseName "深圳南头仓" ; ex:warehouseCity "深圳" ; ex:warehouseLat 22.54 ; ex:warehouseLng 113.92 .
ex:wh-beijing a ex:Warehouse ; ex:warehouseCode "WH-PEK" ; ex:warehouseName "北京顺义仓" ; ex:warehouseCity "北京" ; ex:warehouseLat 40.13 ; ex:warehouseLng 116.65 .
ex:wh-chengdu a ex:Warehouse ; ex:warehouseCode "WH-CTU" ; ex:warehouseName "成都双流仓" ; ex:warehouseCity "成都" ; ex:warehouseLat 30.58 ; ex:warehouseLng 103.95 .

# === 3 个承运商 ===
ex:car-sf a ex:Carrier ; ex:carrierCode "SF" ; ex:carrierName "顺丰速运" .
ex:car-yt a ex:Carrier ; ex:carrierCode "YT" ; ex:carrierName "圆通速递" .
ex:car-zto a ex:Carrier ; ex:carrierCode "ZTO" ; ex:carrierName "中通快递" .

# === 5 个客户 ===
ex:cust-001 a ex:Customer ; ex:customerName "张三" ; ex:customerPhone "13800000001" ; ex:customerAddress "上海市浦东新区世纪大道 100 号" .
ex:cust-002 a ex:Customer ; ex:customerName "李四" ; ex:customerPhone "13800000002" ; ex:customerAddress "深圳市南山区科技园路 1 号" .
ex:cust-003 a ex:Customer ; ex:customerName "王五" ; ex:customerPhone "13800000003" ; ex:customerAddress "北京市朝阳区建国路 88 号" .
ex:cust-004 a ex:Customer ; ex:customerName "赵六" ; ex:customerPhone "13800000004" ; ex:customerAddress "成都市武侯区天府大道 50 号" .
ex:cust-005 a ex:Customer ; ex:customerName "孙七" ; ex:customerPhone "13800000005" ; ex:customerAddress "广州市天河区珠江路 30 号" .

# === 8 个订单 ===
ex:o-001 a ex:Order ; ex:orderNo "O0000000001" ; ex:orderCustomer ex:cust-001 ; ex:orderWarehouse ex:wh-shanghai ; ex:orderWeight 2.5 ; ex:orderDate "2026-07-01T10:00:00"^^xsd:dateTime ; ex:orderStatus "Delivered" .
ex:o-002 a ex:Order ; ex:orderNo "O0000000002" ; ex:orderCustomer ex:cust-002 ; ex:orderWarehouse ex:wh-shenzhen ; ex:orderWeight 1.2 ; ex:orderDate "2026-07-02T11:00:00"^^xsd:dateTime ; ex:orderStatus "Delivered" .
ex:o-003 a ex:Order ; ex:orderNo "O0000000003" ; ex:orderCustomer ex:cust-003 ; ex:orderWarehouse ex:wh-beijing ; ex:orderWeight 5.0 ; ex:orderDate "2026-07-03T09:00:00"^^xsd:dateTime ; ex:orderStatus "Shipped" .
ex:o-004 a ex:Order ; ex:orderNo "O0000000004" ; ex:orderCustomer ex:cust-004 ; ex:orderWarehouse ex:wh-chengdu ; ex:orderWeight 3.8 ; ex:orderDate "2026-07-04T14:00:00"^^xsd:dateTime ; ex:orderStatus "Delivered" .
ex:o-005 a ex:Order ; ex:orderNo "O0000000005" ; ex:orderCustomer ex:cust-005 ; ex:orderWarehouse ex:wh-shenzhen ; ex:orderWeight 8.5 ; ex:orderDate "2026-07-05T15:00:00"^^xsd:dateTime ; ex:orderStatus "Shipped" .
ex:o-006 a ex:Order ; ex:orderNo "O0000000006" ; ex:orderCustomer ex:cust-001 ; ex:orderWarehouse ex:wh-shanghai ; ex:orderWeight 1.0 ; ex:orderDate "2026-07-06T16:00:00"^^xsd:dateTime ; ex:orderStatus "Delivered" .
ex:o-007 a ex:Order ; ex:orderNo "O0000000007" ; ex:orderCustomer ex:cust-002 ; ex:orderWarehouse ex:wh-shenzhen ; ex:orderWeight 12.0 ; ex:orderDate "2026-07-07T17:00:00"^^xsd:dateTime ; ex:orderStatus "Shipped" .
ex:o-008 a ex:Order ; ex:orderNo "O0000000008" ; ex:orderCustomer ex:cust-003 ; ex:orderWarehouse ex:wh-beijing ; ex:orderWeight 0.5 ; ex:orderDate "2026-07-08T18:00:00"^^xsd:dateTime ; ex:orderStatus "Created" .

# === 8 个运单（8 订单各对应 1 运单）===
ex:s-001 a ex:GroundShipment ; ex:shipmentOf ex:o-001 ; ex:shipmentCarrier ex:car-sf ;
