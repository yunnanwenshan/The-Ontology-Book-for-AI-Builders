    ex:shipmentDate "2026-07-01T18:00:00"^^xsd:dateTime ;
    ex:estimatedArrival "2026-07-03T12:00:00"^^xsd:dateTime ;
    ex:actualArrival   "2026-07-03T10:30:00"^^xsd:dateTime .

