    ex:shipmentDate "2026-07-04T16:00:00"^^xsd:dateTime ;
    ex:estimatedArrival "2026-07-07T18:00:00"^^xsd:dateTime ;
    ex:actualArrival   "2026-07-09T09:00:00"^^xsd:dateTime .   # 延误 2 天

ex:s-005 a ex:SeaShipment ; ex:shipmentOf ex:o-005 ; ex:shipmentCarrier ex:car-sf ;
    ex:trackingNo "SF5678901234" ; ex:shipmentStatus "InTransit" ;
    ex:shipmentDate "2026-07-05T22:00:00"^^xsd:dateTime ;
    ex:estimatedArrival "2026-07-15T18:00:00"^^xsd:dateTime .

ex:s-006 a ex:GroundShipment ; ex:shipmentOf ex:o-006 ; ex:shipmentCarrier ex:car-yt ;
