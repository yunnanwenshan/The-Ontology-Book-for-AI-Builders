    ex:shipmentDate "2026-07-08T22:00:00"^^xsd:dateTime ;
    ex:estimatedArrival "2026-07-10T18:00:00"^^xsd:dateTime .

# === 10 个轨迹事件（4 运单）===
ex:ev-001 a ex:TrackingEvent ; ex:eventOf ex:s-001 ; ex:eventType "Pickup" ; ex:eventLocation "上海主仓" ; ex:eventTime "2026-07-01T18:00:00"^^xsd:dateTime .
ex:ev-002 a ex:TrackingEvent ; ex:eventOf ex:s-001 ; ex:eventType "Arrival"  ; ex:eventLocation "上海浦东" ; ex:eventTime "2026-07-02T08:00:00"^^xsd:dateTime .
ex:ev-003 a ex:TrackingEvent ; ex:eventOf ex:s-001 ; ex:eventType "Delivered"; ex:eventLocation "上海浦东客户" ; ex:eventTime "2026-07-03T10:30:00"^^xsd:dateTime .

ex:ev-004 a ex:TrackingEvent ; ex:eventOf ex:s-003 ; ex:eventType "Pickup" ; ex:eventLocation "北京顺义仓" ; ex:eventTime "2026-07-03T20:00:00"^^xsd:dateTime .
ex:ev-005 a ex:TrackingEvent ; ex:eventOf ex:s-003 ; ex:eventType "ArrivalTransit" ; ex:eventLocation "上海转运中心" ; ex:eventTime "2026-07-04T06:00:00"^^xsd:dateTime .
ex:ev-006 a ex:TrackingEvent ; ex:eventOf ex:s-003 ; ex:eventType "DepartureTransit" ; ex:eventLocation "上海转运中心" ; ex:eventTime "2026-07-04T14:00:00"^^xsd:dateTime .

ex:ev-007 a ex:TrackingEvent ; ex:eventOf ex:s-004 ; ex:eventType "Pickup" ; ex:eventLocation "成都双流仓" ; ex:eventTime "2026-07-04T16:00:00"^^xsd:dateTime .
ex:ev-008 a ex:TrackingEvent ; ex:eventOf ex:s-004 ; ex:eventType "Delivered" ; ex:eventLocation "成都武侯客户" ; ex:eventTime "2026-07-09T09:00:00"^^xsd:dateTime .

ex:ev-009 a ex:TrackingEvent ; ex:eventOf ex:s-007 ; ex:eventType "Pickup" ; ex:eventLocation "深圳南头仓" ; ex:eventTime "2026-07-07T22:00:00"^^xsd:dateTime .
ex:ev-010 a ex:TrackingEvent ; ex:eventOf ex:s-007 ; ex:eventType "Exception" ; ex:eventLocation "广州白云机场" ; ex:eventTime "2026-07-08T14:00:00"^^xsd:dateTime .

# === 3 个异常 ===
ex:exc-001 a ex:DelayException ; ex:exceptionOf ex:s-004 ;
    ex:exceptionType "延误" ; ex:exceptionDesc "天气原因导致延误 2 天" ;
    ex:exceptionTime "2026-07-08T10:00:00"^^xsd:dateTime ;
    ex:exceptionStatus "Resolved" .

ex:exc-002 a ex:DamageException ; ex:exceptionOf ex:s-007 ;
    ex:exceptionType "破损" ; ex:exceptionDesc "外包装破损 1 处" ;
    ex:exceptionTime "2026-07-08T14:30:00"^^xsd:dateTime ;
    ex:exceptionStatus "Open" .

ex:exc-003 a ex:LostException ; ex:exceptionOf ex:s-007 ;
    ex:exceptionType "丢件" ; ex:exceptionDesc "清关时少 1 件" ;
    ex:exceptionTime "2026-07-08T15:00:00"^^xsd:dateTime ;
    ex:exceptionStatus "Investigating" .
