            owl:cardinality 1 ;
            owl:onProperty ex:employeeId ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty ex:employeeId ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty ex:employeeId ],
